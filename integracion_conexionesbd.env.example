# Integraciones_OS — Conexiones a BD (plantilla)
# Copiar a `integracion_conexionesbd.env` (mismo directorio) y completar con credenciales reales.
# El archivo real NO va a git.

# ─── MariaDB LOCAL ───────────────────────────────────────────────────
DB_LOCAL_HOST=127.0.0.1
DB_LOCAL_PORT=3306
DB_LOCAL_USER=usuario_local
DB_LOCAL_PASS=clave_local

# ─── INTEGRACIÓN ─────────────────────────────────────────────────────
DB_INTEGRACION_SSH_HOST=ssh.ejemplo.com
DB_INTEGRACION_SSH_PORT=22
DB_INTEGRACION_SSH_USER=ssh_user
DB_INTEGRACION_SSH_KEY=/ruta/a/llave_privada
DB_INTEGRACION_REMOTE_HOST=127.0.0.1
DB_INTEGRACION_REMOTE_PORT=3306
DB_INTEGRACION_NAME=os_integracion
DB_INTEGRACION_USER=db_user
DB_INTEGRACION_PASS=db_pass
DB_INTEGRACION_LOCAL_PORT=3311

# ─── GESTIÓN ─────────────────────────────────────────────────────────
DB_GESTION_SSH_HOST=ssh.ejemplo.com
DB_GESTION_SSH_PORT=22
DB_GESTION_SSH_USER=ssh_user
DB_GESTION_SSH_KEY=/ruta/a/llave_privada
DB_GESTION_REMOTE_HOST=127.0.0.1
DB_GESTION_REMOTE_PORT=3306
DB_GESTION_NAME=os_gestion
DB_GESTION_USER=db_user
DB_GESTION_PASS=db_pass
DB_GESTION_LOCAL_PORT=3312

# ─── MASTER ──────────────────────────────────────────────────────────
DB_MASTER_SSH_HOST=ssh.ejemplo.com
DB_MASTER_SSH_PORT=22
DB_MASTER_SSH_USER=ssh_user
DB_MASTER_SSH_KEY=/ruta/a/llave_privada
DB_MASTER_REMOTE_HOST=127.0.0.1
DB_MASTER_REMOTE_PORT=3306
DB_MASTER_NAME=sos_master_erp
DB_MASTER_USER=os_master
DB_MASTER_PASS=clave_master
DB_MASTER_LOCAL_PORT=3314

# ─── COMUNIDAD ───────────────────────────────────────────────────────
DB_COMUNIDAD_SSH_HOST=ssh.ejemplo.com
DB_COMUNIDAD_SSH_PORT=22
DB_COMUNIDAD_SSH_USER=ssh_user
DB_COMUNIDAD_SSH_KEY=/ruta/a/llave_privada
DB_COMUNIDAD_REMOTE_HOST=127.0.0.1
DB_COMUNIDAD_REMOTE_PORT=3306
DB_COMUNIDAD_NAME=os_comunidad
DB_COMUNIDAD_USER=db_user
DB_COMUNIDAD_PASS=db_pass
DB_COMUNIDAD_LOCAL_PORT=3313

# ─── TIMEZONE — una sola fuente para Node, Python, MySQL, frontend ──
# Cambiar acá cuando la operación se mueva de país. Todo el código lo lee de aquí,
# nunca hardcodear "-05:00" ni "America/Bogota" en ningún otro archivo.
APP_TIMEZONE=-05:00
APP_TIMEZONE_NAME=America/Bogota

# Alias legacy para código que aún lee DB_TIMEZONE
DB_TIMEZONE=-05:00
